# Configuración para Google Apps Script
# Copia esto a tu archivo .env en el backend/

# URL de tu Google Apps Script Web App
APPS_SCRIPT_URL=https://script.google.com/macros/s/AKfycbw7ttRErXXgmTkIHN_GedGdCWOqk-BylXQoUhD0Kk6P9VwrJWRJ81ROO19V5PlI9lIY/exec

# Proveedor de IA por defecto
DEFAULT_AI_PROVIDER=ollama

# Modelo de Ollama
OLLAMA_MODEL=llama3

# URL base de Ollama
OLLAMA_BASE_URL=http://localhost:11434

# API Key de Groq (opcional, si quieres usar Groq en vez de Ollama)
GROQ_API_KEY=

# Modelo de Groq
GROQ_MODEL=llama3-8b-8192
